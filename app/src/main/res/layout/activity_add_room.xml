<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thông Tin Phòng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mã phòng *"/>
        <EditText
            android:id="@+id/etMa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="VD: P01"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên phòng *"/>
        <EditText
            android:id="@+id/etTen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="VD: Phòng 101"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giá thuê (VNĐ/tháng) *"/>
        <EditText
            android:id="@+id/etGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="VD: 2500000"
            android:inputType="numberDecimal"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <CheckBox
            android:id="@+id/cbDaThue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đã có người thuê"
            android:layout_marginBottom="10dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên người thuê"/>
        <EditText
            android:id="@+id/etNguoiThue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Để trống nếu chưa có"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại"/>
        <EditText
            android:id="@+id/etSdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="VD: 0901234567"
            android:inputType="phone"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnLuu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Lưu"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnHuy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hủy"
            android:backgroundTint="#757575"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
